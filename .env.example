# Supabase — project URL + publishable (anon) key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret key: server-side only (API routes). Bypasses RLS — never NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=

# BytePlus ModelArk (Seedance / Seedream) — copy to .env.local and fill in.
ARK_API_KEY=

# Anthropic — powers the Strategist + Director script writing when set
# (falls back to the Ark LLM when unset). Create at console.anthropic.com.
ANTHROPIC_API_KEY=
# Optional model override (default claude-opus-4-8):
# ANTHROPIC_MODEL=

# Stripe — our payment processor (set in Vercel, Production + Preview).
# We create Checkout Sessions server-side with inline prices from the billing
# catalog, so there are no per-item price ids to configure in Stripe.
# Use sk_test_… keys to test; sk_live_… to charge for real.
STRIPE_SECRET_KEY=
# Signing secret of the webhook endpoint pointing at /api/stripe/webhook
# (Stripe dashboard → Developers → Webhooks → your endpoint → Signing secret),
# subscribed to checkout.session.completed, checkout.session.async_payment_succeeded,
# and invoice.paid.
STRIPE_WEBHOOK_SECRET=
# Publishable key (public — safe to expose). Powers the in-page Embedded
# Checkout and the account page's card update. Dashboard → Developers → API keys.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Owner dashboard (/admin) allowlist — comma-separated emails. Optional;
# defaults to the owner account in code.
# ADMIN_EMAILS=you@example.com

# Cloudflare Turnstile site key (public). When set — together with enabling
# captcha in Supabase Auth → Attack protection — signups require a captcha,
# which blocks free-credit farming. Unset = captcha off, app works unchanged.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Optional overrides:
# ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
# ARK_IMAGE_MODEL=seedream-3-0-t2i-250415
