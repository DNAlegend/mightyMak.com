# Supabase — project URL + publishable (anon) key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret key: server-side only (API routes). Bypasses RLS — never NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=

# BytePlus ModelArk (Seedance / Seedream) — copy to .env.local and fill in.
ARK_API_KEY=

# Anthropic — powers the Strategist + Director script writing when set
# (falls back to the Ark LLM when unset). Create at console.anthropic.com.
ANTHROPIC_API_KEY=
# Optional model override (default claude-opus-4-8):
# ANTHROPIC_MODEL=

# Mamo (Mamo Pay) — our payment processor (set in Vercel, Production + Preview).
# We create hosted payment links server-side and price them from the billing
# catalog, so there are no per-item price ids to configure.
# Leave unset for sandbox; set to "production" to charge for real.
MAMO_ENV=
# Server-side API key (secret) from Mamo dashboard → Developer → API keys.
MAMO_API_KEY=
# Webhook shared secret: set this exact value as the webhook's auth header in
# the Mamo dashboard (Developer → Webhooks). Mamo echoes it in the Authorization
# header of every delivery, and /api/mamo/webhook verifies it.
MAMO_WEBHOOK_SECRET=
# Optional overrides:
# ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
# ARK_IMAGE_MODEL=seedream-3-0-t2i-250415
