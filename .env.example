# Supabase — project URL + publishable (anon) key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret key: server-side only (API routes). Bypasses RLS — never NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=

# BytePlus ModelArk (Seedance / Seedream) — copy to .env.local and fill in.
ARK_API_KEY=

# Anthropic — powers the Strategist + Director script writing when set
# (falls back to the Ark LLM when unset). Create at console.anthropic.com.
ANTHROPIC_API_KEY=
# Optional model override (default claude-opus-4-8):
# ANTHROPIC_MODEL=

# Paddle — our sole merchant of record (set in Vercel, Production + Preview).
# Leave unset for sandbox; set to "production" to charge for real.
PADDLE_ENV=
# Server-side API key (secret) from Paddle → Developer tools → Authentication.
PADDLE_API_KEY=
# Notification-destination signing secret (whsec_…) from Developer tools → Notifications.
PADDLE_WEBHOOK_SECRET=
# Client-side token (test_… / live_…) used by Paddle.js in the browser.
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# One Paddle price id (pri_…) per billing item — key = PADDLE_PRICE_<ITEM_ID upper, - → _>.
PADDLE_PRICE_PLAN_CREATOR=
PADDLE_PRICE_PLAN_PRO=
PADDLE_PRICE_PLAN_AGENCY=
PADDLE_PRICE_TOPUP_200=
PADDLE_PRICE_TOPUP_600=
PADDLE_PRICE_TOPUP_1500=
PADDLE_PRICE_TOPUP_5000=
# Optional overrides:
# ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
# ARK_IMAGE_MODEL=seedream-3-0-t2i-250415
