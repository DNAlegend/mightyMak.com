# Supabase — project URL + publishable (anon) key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret key: server-side only (API routes). Bypasses RLS — never NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=

# BytePlus ModelArk (Seedance / Seedream) — copy to .env.local and fill in.
ARK_API_KEY=

# MamoPay payments (server-side only — set in Vercel, Production + Preview).
# Get the API key from dashboard.mamopay.com → Developer → Keys.
MAMOPAY_API_KEY=
# Any long random string; the webhook URL carries it and the route checks it.
MAMOPAY_WEBHOOK_SECRET=
# Leave unset for sandbox; set to "production" to charge for real.
MAMOPAY_ENV=
# Optional overrides:
# ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
# ARK_IMAGE_MODEL=seedream-3-0-t2i-250415
